{
  "file_scan_exclusions": [
    "**/.git",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/.turbo",
    "**/.venv",
    "**/.agents",
    "**/.claude",
    "**/.codex",
    "**/__pycache__",
  ],
  "lsp": {
    "cargo-tom": {
      "initialization_options": {
        "hide_docs_info_message": true,
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "run": "onSave",
        },
      },
    },
  },
  "languages": {
    "JSON": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "JSONC": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TOML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "Markdown": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "YAML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "Rust": {
      "format_on_save": "on",
    },
    "Proto": {
      "format_on_save": "on",
    },
  },
}
